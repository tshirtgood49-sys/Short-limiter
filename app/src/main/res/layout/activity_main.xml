<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:layout_marginBottom="24dp"
        android:text="Status loading..." />

    <Button
        android:id="@+id/btnAccessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Step 1: Accessibility Permission On Karo"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnVpnPermission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Step 2: VPN Permission Do (Block ke liye)"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aaj ki Ginti Reset Karo"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/editLimit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:inputType="number"
            android:hint="Shorts limit"
            android:maxLength="3"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSetLimit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set Limit" />

    </LinearLayout>

    <Button
        android:id="@+id/btnDebugIds"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Debug: ID List Dekho"
        android:layout_marginTop="24dp" />

</LinearLayout>
<Button
        android:id="@+id/btnEventLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Debug: Event Log Dekho"
        android:layout_marginTop="12dp" />
